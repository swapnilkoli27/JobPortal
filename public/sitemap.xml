<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <!-- Static routes -->
  <url>
    <loc>https://yourjobportal.com/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://yourjobportal.com/jobs</loc>
    <changefreq>hourly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://yourjobportal.com/categories</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
  <!--
    Dynamic job pages are best generated via a server-side sitemap script
    that reads from Firestore. Example Cloud Function:

    exports.sitemap = functions.https.onRequest(async (req, res) => {
      const snap = await admin.firestore()
        .collection('jobs')
        .where('status', '==', 'published')
        .get()
      const urls = snap.docs.map(d =>
        `<url><loc>https://yourjobportal.com/jobs/${d.id}</loc><changefreq>weekly</changefreq></url>`
      ).join('')
      res.set('Content-Type', 'application/xml')
      res.send(`<?xml version="1.0"?><urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">${urls}</urlset>`)
    })
  -->
</urlset>
